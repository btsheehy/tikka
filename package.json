{
  "name": "tikka",
  "version": "1.0.0",
  "description": "Minimal dependency-free functional programming utilities for TypeScript and JavaScript",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./all": {
      "types": "./dist/tikka.d.ts",
      "import": "./dist/tikka.js",
      "require": "./dist/tikka.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && rollup -c",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btsheehy/tikka.git"
  },
  "keywords": [
    "functional",
    "programming",
    "utilities",
    "typescript",
    "tree-shaking"
  ],
  "author": "Brandon Sheehy <dev@btsheehy.com>",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/btsheehy/tikka/issues"
  },
  "homepage": "https://github.com/btsheehy/tikka#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.6.1",
    "rollup": "^4.52.5",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
