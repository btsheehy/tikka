{
  "name": "tikka",
  "version": "1.0.0",
  "description": "Minimal Functional Programming Library",
  "sideEffects": false,
  "main": "dist/tikka.cjs.js",
  "module": "dist/tikka.esm.js",
  "browser": "dist/tikka.umd.js",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1",
    "check": "npx @biomejs/biome check src/",
    "check:write": "npx @biomejs/biome check src/ --write",
    "format": "npx @biomejs/biome format src/",
    "format:write": "npx @biomejs/biome format src/ --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btsheehy/tikka.git"
  },
  "keywords": [
    "functional",
    "programming",
    "utils",
    "curry"
  ],
  "author": "Brandon Sheehy <dev@btsheehy.com>",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/btsheehy/tikka/issues"
  },
  "homepage": "https://github.com/btsheehy/tikka#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@rollup/plugin-typescript": "^8.2.0",
    "rollup": "^1.13.1",
    "rollup-plugin-commonjs": "^10.0.0",
    "rollup-plugin-node-resolve": "^5.0.1",
    "tslib": "^2.1.0",
    "typescript": "^4.2.2"
  }
}
